<style>
    .filters {
        display: flex;
        /* max-width: 100%; */
        overflow-x: auto;
        gap: 1rem;
        scrollbar-width: none; /*firefox*/
        -ms-overflow-style: none; /*IE and edge*/
    }

    .filters::-webkit-scrollbar {
        display: none; /* Chrome, Safari */
    }

    /* both sides fade */
    .filters.fade-both {
        -webkit-mask-image: linear-gradient(to right, transparent, black 110px, black calc(100% - 110px), transparent);
        mask-image: linear-gradient(to right, transparent, black 110px, black calc(100% - 110px), transparent);
    }

    /* only right fade */
    .filters.fade-right {
        -webkit-mask-image: linear-gradient(to right, black calc(100% - 110px), transparent);
        mask-image: linear-gradient(to right, black calc(100% - 110px), transparent);
    }

    /* only left fade */
    .filters.fade-left {
        -webkit-mask-image: linear-gradient(to right, transparent, black 110px);
        mask-image: linear-gradient(to right, transparent, black 110px);
    }

    .filter {
        opacity: 0.8;
        text-align: center;
        padding: 0.6rem 0.6rem 0 0.6rem;
        border: 1px solid transparent;
    }

    .filter:hover{
        opacity: 1;
        cursor: pointer;
    }

    .filter p {
        font-size: 0.8rem;
    }

    .btn.scroll-left, .btn.scroll-right {
        border: 1px solid black;
        font-size: 0.8rem;
        width: 2rem;
        height: 2rem;
        text-align: center;
        border-radius: 50%;
        background-color: white;
    }

    .btn.scroll-left:hover, .btn.scroll-right:hover {
        box-shadow: 0 0 5px black;
        background-color: rgb(243, 243, 243);
    }
     
    .arrow-left, .arrow-right {
        display: flex;
        align-items: center;
    }

    .filter p {
        text-wrap: nowrap;
    }

    @media (max-width: 768px) {
        .btn.scroll-left, .btn.scroll-right {
            display: none;
        }
    }

    .filters input[type="checkbox"] {
        position: absolute;
        opacity: 0;
        width: 0;            
        height: 0;           
        margin: 0;
        padding: 0;
        cursor: pointer; 
    }

    .filter:has(input:checked){
        border: 1px solid black;
        border-radius: 1rem;
        opacity: 1;
    }

</style>
    
<div class="row g-0 mt-3 mb-3 mt-lg-4 mb-lg-4">
    <div class="arrow-left col-md-1">
        <div class="btn scroll-left " onclick="scrollFilters(-1)">&#10094;</div>
    </div>
    <div class="col-12 col-md-10">
        <div class="filters">
            <div class="filter">
                <label>
                    <div><i class="fa-solid fa-fire"></i></div>
                    <p>Trending</p>
                    <input type="checkbox" name="categories[]" value="Trending">
                </label>
            </div>
            <div class="filter">
                <label>
                    <div><i class="fa-solid fa-bed"></i></div>
                    <p>Rooms</p>
                    <input type="checkbox" name="categories[]" value="Rooms">
                </label>
            </div>
            <div class="filter">
                <label>
                    <div><i class="fa-solid fa-mountain-city"></i></div>
                    <p>Iconic cities</p>
                    <input type="checkbox" name="categories[]" value="Iconic cities">
                </label>
            </div>
            <div class="filter">
                <label>
                    <div><i class="fa-solid fa-mountain"></i></div>
                    <p>Mountains</p>
                    <input type="checkbox" name="categories[]" value="Mountains">
                </label>
            </div>
            <div class="filter">
                <label>
                    <div><i class="fa-solid fa-person-swimming"></i></div>
                    <p>Amazing pool</p>
                    <input type="checkbox" name="categories[]" value="Amazing pool">
                </label>
            </div>
            <div class="filter">
                <label>
                    <div><i class="fa-brands fa-fort-awesome"></i></div>
                    <p>Castles</p>
                    <input type="checkbox" name="categories[]" value="Castles">
                </label>
            </div>
            <div class="filter">
                <label>
                    <div><i class="fa-solid fa-campground"></i></div>
                    <p>Camping</p>
                    <input type="checkbox" name="categories[]" value="Camping">
                </label>
            </div>
            <div class="filter">
                <label>
                    <div><i class="fa-solid fa-cow"></i></div>
                    <p>Farms</p>
                    <input type="checkbox" name="categories[]" value="Farms">
                </label>
            </div>
            <div class="filter me-4">
                <label>
                    <div><i class="fa-regular fa-snowflake"></i></div>
                    <p>Arctic</p>
                    <input type="checkbox" name="categories[]" value="Arctic">
                </label>
            </div>
        </div>
    </div>
    <div class="arrow-right col-md-1">
        <div class="btn scroll-right" onclick="scrollFilters(1)">&#10095;</div>
    </div>
</div>

<script>
    function scrollFilters(direction) {
        const container = document.getElementsByClassName("filters")[0];
        const scrollAmount = 200;

        container.scrollBy({
        left: direction * scrollAmount,
        behavior: "smooth"
        });
    }

    const leftBtn = document.querySelector(".scroll-left");
    const rightBtn = document.querySelector(".scroll-right");
 
    const container = document.querySelector(".filters");

    function updateFade() {
        const scrollLeft = container.scrollLeft;
        const maxScroll = container.scrollWidth - container.clientWidth;

        container.classList.remove("fade-left", "fade-right", "fade-both");


        if (scrollLeft <= 0) {
            // at start → only right fade
            container.classList.add("fade-right");
            leftBtn.style.opacity = 0.2;
            rightBtn.style.opacity = 1;
        } else if (scrollLeft >= maxScroll - 1) {
            // at end → only left fade
            container.classList.add("fade-left");
            leftBtn.style.opacity = 1;
            rightBtn.style.opacity = 0.2;
        } else {
            // middle → both fades
            container.classList.add("fade-both");
            leftBtn.style.opacity = 1;
            rightBtn.style.opacity = 1;
        }
    }

    container.addEventListener("scroll", updateFade);

    // run on load
    window.addEventListener("load", updateFade);


</script>