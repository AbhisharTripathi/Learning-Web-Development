<% layout("/layouts/boilerplate.ejs") %>

<style>
    .hidden-tax {
        display: none;
    }

    .tax-toggle {
        border: 1px solid black;
        border-radius: 1rem;
        height: 3rem;
        align-self: center;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .applyBtn {
        padding: 0.5rem 1rem;
        border-radius: 1rem;
        border: 1px solid #fe424d;
        color: #fe424d;
        background-color: white;
        font-weight: 500;
        opacity: 1;
    }

    @media(min-width: 992px) {
        .applyBtn {
            transform: translateX(-15px);
        }
    }

    @media(min-width: 0px) and (max-width: 767px) {
        .applyBtn {
            font-size: 0.8rem;
            padding: 0.5rem 0.75rem;
        }
    }

    .applyBtn.apply {
        color: white;
        background-color: #fe424d;
    }

    .applyBtn.apply:hover {
        box-shadow: 0 0 5px #fe424d;
        transition: 0.15s;
    }
</style>

<body>
    <div class="row g-0">
        <div class="col-lg-9 col-10"><%- include("../includes/filters.ejs") %></div>
        <div class="col-lg-1 col-2 d-flex align-items-center justify-content-center">
            <button class="applyBtn">Apply</button>
        </div>
        <div class="tax-toggle col-lg-2 mb-lg-0 mb-3">
            <div class="form-check-reverse form-switch">
                <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
                <label class="form-check-label" for="switchCheckDefault">Include Taxes</label>
            </div>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-lg-3 row-cols-md-2 row-cols-sm-1 allListingsDiv">
        <%for(let listing of allListings) { %>
            <div class="col">
                <a href="/listings/<%= listing._id %>" class="listing-link">
                    <div class="card listing-card" >
                        <img src="<%= listing.image.url  +'?w=500&h=240&q=75&auto=format&fit=crop' %>" class="card-img-top" alt="Image is present here" loading="lazy">
                        <div class="card-img-overlay">&#9825; &#9829;</div>
                        <div class="card-body">
                            <p class="card-text">
                                <b><%= listing.title %></b>
                                <br>
                                <span>&#8377; <%= listing.price.toLocaleString("en-IN") %> / night </span> <span class="hidden-tax tax"><i>+ 18% GST</i></span>
                            </p>
                        </div>
                    </div>
                </a>
            </div>
        <% } %>
    </div>
</body>

<script>
    let taxToggle = document.getElementById('switchCheckDefault');
    taxToggle.addEventListener("change", (event) => {
        let priceInfo = document.getElementsByClassName("tax");
        if(event.target.checked) {
            for(let el of priceInfo) {
                el.classList.remove("hidden-tax");
            }
        }
        else {
            for(let el of priceInfo) {
                el.classList.add("hidden-tax");
            }
        }
    });


    let applyBtn = document.querySelector(".applyBtn");
    let filterList = [];
    function handleFilterChange() {
  
        applyBtn.classList.add("apply");

        if(this.checked) {
            filterList.push(this.value);
        } else {
            filterList = filterList.filter(el => el !== this.value);
        }
    }

    async function handleApplyFilter() {
        let response = await fetch(`/api/filter?filters=${filterList.join(",")}`);
        let filteredListings = await response.json();
        applyBtn.classList.remove("apply");
        let allListingsDiv = document.querySelector(".allListingsDiv");
        allListingsDiv.innerText = "";
        for(let listing of filteredListings) {
            let newInnerHTML = `<div class="col">
                <a href="/listings/${ listing._id }" class="listing-link">
                    <div class="card listing-card" >
                        <img src="${ listing.image.url +'?w=500&h=240&q=75&auto=format&fit=crop' }" class="card-img-top" alt="Image is present here" loading="lazy">
                        <div class="card-img-overlay">&#9825; &#9829;</div>
                        <div class="card-body">
                            <p class="card-text">
                                <b>${ listing.title }</b>
                                <br>
                                <span>&#8377; ${ listing.price.toLocaleString("en-IN") } / night </span> <span class="hidden-tax tax"><i>+ 18% GST</i></span>
                            </p>
                        </div>
                    </div>
                </a>
            </div>`;

            allListingsDiv.innerHTML = allListingsDiv.innerHTML + newInnerHTML;
        }
    }

    let allFilterInputs = document.querySelectorAll(".filter input");
    for(let filterInput of allFilterInputs) {
        filterInput.addEventListener("change", handleFilterChange);
    }
    applyBtn.addEventListener("click", handleApplyFilter);

</script>

