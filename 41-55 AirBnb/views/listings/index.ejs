<% layout("/layouts/boilerplate.ejs") %>
<style>
    .filter {
        /* border: 1px solid black;
        border-radius: 1rem; */
        opacity: 0.8;
        margin-left: 1rem;
        text-align: center;
    }

    .filter:hover{
        opacity: 1;
        cursor: pointer;
    }

    .filter p {
        font-size: 0.8rem;
    }

    .hidden-tax {
        display: none;
    }

    .tax-toggle {
        border: 1px solid black;
        border-radius: 1rem;
        height: 3rem;
        align-self: center;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>

<body>
    <div class="row">
        <div class="filters mt-4 row col-md-9">
            <div class="filter col">
                <div><i class="fa-solid fa-fire"></i></div>
                <p>Trending</p>
            </div>
            <div class="filter col">
                <div><i class="fa-solid fa-bed"></i></div>
                <p>Rooms</p>
            </div>
            <div class="filter col">
                <div><i class="fa-solid fa-mountain-city"></i></div>
                <p>Iconic cities</p>
            </div>
            <div class="filter col">
                <div><i class="fa-solid fa-mountain"></i></div>
                <p>Mountains</p>
            </div>
            <div class="filter col">
                <div><i class="fa-solid fa-person-swimming"></i></div>
                <p>Amazing pool</p>
            </div>
            <div class="filter col">
                <div><i class="fa-brands fa-fort-awesome"></i></div>
                <p>Castles</p>
            </div>
            <div class="filter col">
                <div><i class="fa-solid fa-campground"></i></div>
                <p>Camping</p>
            </div>
            <div class="filter col">
                <div><i class="fa-solid fa-cow"></i></div>
                <p>Farms</p>
            </div>
            <div class="filter col">
                <div><i class="fa-regular fa-snowflake"></i></div>
                <p>Arctic</p>
            </div>
        </div>
        <div class="tax-toggle col">
            <div class="form-check-reverse form-switch">
                <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
                <label class="form-check-label" for="switchCheckDefault">Display total after Taxes</label>
            </div>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
        <%for(let listing of allListings) { %>
            <div class="col">
                <a href="/listings/<%= listing._id %>" class="listing-link">
                    <div class="card listing-card" >
                        <img src="<%= listing.image.url+'?w=500&h=240&q=75&auto=format&fit=crop' %>" class="card-img-top" alt="Image is present here" loading="lazy">
                        <div class="card-img-overlay">&#9825; &#9829;</div>
                        <div class="card-body">
                            <p class="card-text">
                                <b><%= listing.title %></b>
                                <br>
                                <span>&#8377; <%= listing.price.toLocaleString("en-IN") %> / night </span> <span class="hidden-tax tax"><i>+ 18% GST</i></span>
                            </p>
                        </div>
                    </div>
                </a>
            </div>
        <% } %>
    </div>
</body>

<script>
    let taxToggle = document.getElementById('switchCheckDefault');
    taxToggle.addEventListener("change", (event) => {
        let priceInfo = document.getElementsByClassName("tax");
        if(event.target.checked) {
            for(let el of priceInfo) {
                el.classList.remove("hidden-tax");
            }
        }
        else {
            for(let el of priceInfo) {
                el.classList.add("hidden-tax");
            }
        }
    })
</script>

