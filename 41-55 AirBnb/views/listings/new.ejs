<% layout("/layouts/boilerplate.ejs") %>
<body>
    <div class="row mt-4">
        <h3>Enter Detail for your new listing</h3>
        <div class="col-md-8">
            <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data"><!--multipart/form-data allows us to send files through form.-->
                <div class="mb-3">
                    <label for="title" class="form-label">Title : </label>
                    <input id="title" name="listing[title]" type="text" placeholder="Enter the Title" class="form-control" required>
                    <div class="valid-feedback">Title is valid.</div>
                    <div class="invalid-feedback">Title is required.</div>
                </div>
                <div class="row">
                    <div class="mb-3 col-md-4">
                        <label for="country" class="form-label">Country : </label>
                        <input id="country" name="listing[country]" type="text" placeholder="Enter the Country" class="form-control" required>
                    </div>
                    <div class="mb-3 col-md-8">
                        <label for="location" class="form-label">Location : </label>
                        <input id="location" name="listing[location]" type="text" placeholder="Enter the Location" class="form-control" required>
                    </div>
                </div>
                <div class="mb-3">
                    <label for="price" class="form-label">Price : </label>
                    <input id="price" name="listing[price]" type="number" placeholder="Enter the Price" class="form-control" required>
                </div>
                <!-- <div class="mb-3">
                    <label for="image-url" class="form-label">Image : </label>
                    <input id="image-url" name="listing[image-url]" type="text" placeholder="Enter image URL" class="form-control">
                </div> -->
                <div class="mb-3">
                    <label for="image" class="form-label">Image : </label>
                    <input id="image" name="listing[image]" type="file" class="form-control" required>
                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">Description :-</label>
                    <textarea id="description" name="listing[description]" rows="4" placeholder="Description about the property." class="form-control" required></textarea>
                </div>
                
                <div class="mb-3">
                    <button type="reset" class="btn new-form-btn">Reset</button>&nbsp;&nbsp;
                    <button type="submit" class="btn new-form-btn">Add</button>
                </div>
            </form>
        </div>
    </div>
</body>