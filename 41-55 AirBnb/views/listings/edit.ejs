<% layout("/layouts/boilerplate.ejs") %>

<body>
    <div class="row mt-4">
        <h3 class="mb-4">Edit this Listing</h3>
        <div class="text-center text-md-start ">
            <img src="<%= listing.image %>" alt="listing image" class="edit-img mb-3 col-12 col-md-5">
        </div>
        <div class="col-md-8">
            <form method="POST" action="/listings/<%= listing._id %>?_method=PUT">
                <div class="mb-3">
                    <label for="title" class="form-label">Title : </label>
                    <input id="title" name="listing[title]" type="text" value="<%= listing.title %>" class="form-control">
                </div>
                <div class="row">
                    <div class="mb-3 col-md-4">
                        <label for="country" class="form-label">Country : </label>
                        <input id="country" name="listing[country]" type="text" value="<%= listing.country %>" class="form-control">
                    </div>
                    <div class="mb-3 col-md-8">
                        <label for="location" class="form-label">Location : </label>
                        <input id="location" name="listing[location]" type="text" value="<%= listing.location %>" class="form-control">
                    </div>
                </div>
                <div class="mb-3">
                    <label for="price" class="form-label">Price : </label>
                    <input id="price" name="listing[price]" type="number" value="<%= listing.price %>" class="form-control">
                </div>
                <div class="mb-3">
                    <label for="image" class="form-label">Image : </label>
                    <input id="image" name="listing[image]" type="text" value="<%= listing.image %>" class="form-control">
                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">Description :-</label>
                    <textarea id="description" name="listing[description]" rows="4" class="form-control"><%= listing.description %></textarea>
                </div>
                
                <div class="mb-3">
                    <button type="reset" class="btn edit-form-btn">Reset</button>&nbsp;&nbsp;
                    <button type="submit" class="btn edit-form-btn">Submit</button>
                </div>
            </form>
        </div>
    </div>
</body>