<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/style.css">
    <title>All Posts</title>
</head>
<body>
    <h1>Quora Posts</h1>
    <% for(let post of posts) { %>
        <hr>
        <div class="post">
            <h3 class="user">@<%= post.username %></h3>
            <p class="content"><%= post.content %></p>
            <a href="http://localhost:8080/posts/<%= post.id %>"><button>View Post</button></a>
            <a href="http://localhost:8080/posts/<%= post.id %>/edit"><button>Edit Post</button></a>
            <form method="post" action="http://localhost:8080/posts/<%= post.id %>?_method=DELETE">
                <button type="submit">Delete Post</button>
            </form><!--we can also use enventlistener with axios to send this request-->
        </div>
    <% } %>
    <hr>
    <br>
    <a href="http://localhost:8080/posts/new"><button>Create new Post</button></a>
</body>
</html>